{
  "name": "zerotwo-build",
  "version": "1.0.0",
  "private": true,
  "description": "Compiles the ZeroTwo dashboard sources into the single self-contained ../index.html",
  "scripts": {
    "build": "babel src --out-dir compiled --presets @babel/preset-react --extensions .jsx && node assemble.js",
    "test": "node smoke-test.js && node interactive-test.js",
    "rebuild": "npm run build && npm test"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "jsdom": "^24.1.3"
  }
}
